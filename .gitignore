# ============================================================================
# IU Smart Study Planner - Comprehensive .gitignore
# ============================================================================

# ============================================================================
# SECURITY - CRITICAL: Never commit these!
# ============================================================================
# Environment variables - Contains secrets, API keys, passwords
.env
.env.*
!.env.example
!.env.template

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
*/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
dist/
dist-ssr/
build/
*/dist/
*/build/
*.local

# ============================================================================
# FRONTEND (React/Vite)
# ============================================================================
# Vite
*.timestamp-*.mjs

# React
.eslintcache
.stylelintcache

# TypeScript
*.tsbuildinfo

# ============================================================================
# BACKEND (Node.js/Express)
# ============================================================================
# Compiled output
server/dist/
server/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output/

# ============================================================================
# DATABASE
# ============================================================================
# Prisma
*.db
*.db-journal
prisma/migrations/*
!prisma/migrations/migration_lock.toml

# PostgreSQL data volumes
postgres_data/
data/
pgdata/

# ============================================================================
# DOCKER
# ============================================================================
.dockerignore
Dockerfile.*.local
docker-compose.*.yml
!docker-compose.yml
!docker-compose.prod.yml

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*

# ============================================================================
# IDE & EDITORS
# ============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# IntelliJ / WebStorm / PhpStorm
.idea/
*.iml
*.iws
*.ipr
out/
atlassian-ide-plugin.xml

# Vim
*.swp
*.swo
*~
.netrwhist

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ============================================================================
# TESTING
# ============================================================================
coverage/
.nyc_output/
*.lcov
coverage.*

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Jest
jest.config.js.snap

# ============================================================================
# DEPLOYMENT
# ============================================================================
.vercel
.netlify
.firebase

# ============================================================================
# MISC
# ============================================================================
.cache/
.parcel-cache/
.temp/
tmp/
temp/
*.tgz
*.tar.gz

# Local development
*.local
.local/

# Debug
.node_repl_history

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ============================================================================
# PROJECT SPECIFIC
# ============================================================================
# Keep these!
!.github/
!.vscode/extensions.json
!.vscode/settings.json
